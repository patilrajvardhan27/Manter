{
  "name": "manter",
  "private": true,
  "workspaces": ["mobile", "server", "shared"],
  "pnpm": { "overrides": {} },
  "scripts": {
    "mobile": "pnpm --filter manter-mobile start",
    "server": "pnpm --filter manter-server dev",
    "db:migrate": "pnpm --filter manter-server db:migrate",
    "db:generate": "pnpm --filter manter-server db:generate",
    "assets": "cd server && node ../scripts/generate-assets.mjs",
    "build:server": "pnpm --filter manter-server build"
  },
  "packageManager": "pnpm@9.0.0"
}
